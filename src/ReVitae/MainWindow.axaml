<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:ReVitae.Core.Localization;assembly=ReVitae.Core"
        x:Class="ReVitae.MainWindow"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="600"
        Width="900"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        Title="ReVitae"
        KeyDown="OnWindowKeyDown"
        SizeChanged="OnWindowSizeChanged">
    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,*"
          Margin="24">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="ReVitae"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock x:Name="HeaderSubtitleTextBlock"
                           Text="Create a simple CV preview and export a plain PDF."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="OpenSetupButton"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnOpenSetupClicked"
                        ToolTip.Tip="Open setup"
                        AutomationProperties.Name="Open setup">
                    <Viewbox Width="26"
                             Height="26"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <TextBlock Text="⚙"
                                   FontSize="26"
                                   TextAlignment="Center" />
                    </Viewbox>
                </Button>

                <Button x:Name="OpenTemplatesButton"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnOpenTemplatesClicked"
                        ToolTip.Tip="Open templates"
                        AutomationProperties.Name="Open templates">
                    <Viewbox Width="26"
                             Height="26"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <TextBlock Text="🎨"
                                   FontSize="26"
                                   TextAlignment="Center" />
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,24,0,0"
              ColumnDefinitions="*,*"
              ColumnSpacing="24">
            <ScrollViewer Grid.Column="0">
                <Border Padding="20"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="14">
                        <TextBlock x:Name="MainPersonalInformationTitleTextBlock"
                                   Text="Main / Personal information"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="FirstNameLabelTextBlock" Text="First name" />
                            <TextBox x:Name="FirstNameTextBox"
                                     PlaceholderText="John"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="FirstNameErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="LastNameLabelTextBlock" Text="Last name" />
                            <TextBox x:Name="LastNameTextBox"
                                     PlaceholderText="Doe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LastNameErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="ProfessionalTitleLabelTextBlock" Text="Professional title" />
                            <TextBox x:Name="ProfessionalTitleTextBox"
                                     PlaceholderText="Frontend Developer"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ProfessionalTitleErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="EmailLabelTextBlock" Text="Email" />
                            <TextBox x:Name="EmailTextBox"
                                     PlaceholderText="john.doe@example.com"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="EmailErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="PhoneLabelTextBlock" Text="Phone" />
                            <TextBox x:Name="PhoneTextBox"
                                     PlaceholderText="+421 900 000 000"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PhoneErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="LocationLabelTextBlock" Text="Location" />
                            <TextBox x:Name="LocationTextBox"
                                     PlaceholderText="Bratislava, Slovakia"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LocationErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="LinkedInUrlLabelTextBlock" Text="LinkedIn URL" />
                            <TextBox x:Name="LinkedInUrlTextBox"
                                     PlaceholderText="https://www.linkedin.com/in/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LinkedInUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="PortfolioUrlLabelTextBlock" Text="Portfolio / website URL" />
                            <TextBox x:Name="PortfolioUrlTextBox"
                                     PlaceholderText="https://johndoe.dev"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PortfolioUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="GitHubUrlLabelTextBlock" Text="GitHub URL" />
                            <TextBox x:Name="GitHubUrlTextBox"
                                     PlaceholderText="https://github.com/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="GitHubUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="ShortSummaryLabelTextBlock" Text="Short summary" />
                            <TextBox x:Name="ShortSummaryTextBox"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     TextWrapping="Wrap"
                                     PlaceholderText="Write two to four sentences about your professional profile."
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ShortSummaryErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <TextBlock x:Name="ValidationSummaryTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />

                        <Button x:Name="ExportPdfButton"
                                Content="Export PDF"
                                HorizontalAlignment="Left"
                                Click="OnExportPdfClicked" />

                        <TextBlock x:Name="ExportStatusTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Padding="20"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="PreviewTitleTextBlock"
                               Text="Preview"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <Border Padding="16"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="6">
                        <ScrollViewer>
                            <ContentControl x:Name="PreviewContentControl" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SetupModalOverlay"
              Grid.RowSpan="2"
              Background="#99000000"
              IsVisible="False">
            <Border x:Name="SetupModalPanel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock x:Name="SetupTitleTextBlock"
                                   Text="Setup"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button x:Name="SetupTopCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="OnCloseSetupClicked" />
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="0,24,0,0"
                                Spacing="12">
                        <TextBlock x:Name="SetupPlaceholderTextBlock"
                                   Text="Setup options will be added in a future step."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="LanguageLabelTextBlock"
                                       Text="Language" />
                            <ComboBox x:Name="LanguageComboBox"
                                      MinWidth="220"
                                      SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="loc:SupportedLanguage">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding FlagEmoji}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding NativeName}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="SetupBottomCloseButton"
                            Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseSetupClicked" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TemplatesModalOverlay"
              Grid.RowSpan="2"
              Background="#99000000"
              IsVisible="False">
            <Border x:Name="TemplatesModalPanel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock x:Name="TemplatesTitleTextBlock"
                                   Text="Templates"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button x:Name="TemplatesTopCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="OnCloseTemplatesClicked" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,24,0,0">
                        <WrapPanel>
                            <Button x:Name="ClassicSidebarTemplateButton"
                                    Width="220"
                                    MinHeight="190"
                                    Margin="0,0,16,16"
                                    Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Click="OnSelectClassicSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Grid Height="86"
                                          ColumnDefinitions="72,*">
                                        <Border Grid.Column="0"
                                                Background="#D0D0D0" />
                                        <Border Grid.Column="1"
                                                Background="White" />
                                    </Grid>
                                    <TextBlock x:Name="ClassicSidebarNameTextBlock"
                                               Text="Classic Sidebar"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ClassicSidebarDescriptionTextBlock"
                                               Text="Light sidebar with contact details and a clean content area."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="ClassicSidebarSelectedTextBlock"
                                               Text="Selected"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="ModernSidebarTemplateButton"
                                    Width="220"
                                    MinHeight="190"
                                    Margin="0,0,16,16"
                                    Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Click="OnSelectModernSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Grid Height="86"
                                          RowDefinitions="28,*"
                                          ColumnDefinitions="72,*">
                                        <Border Grid.RowSpan="2"
                                                Background="#D7D7D7" />
                                        <Border Grid.Column="1"
                                                Background="#444444" />
                                        <Border Grid.Row="1"
                                                Grid.Column="1"
                                                Background="White" />
                                    </Grid>
                                    <TextBlock x:Name="ModernSidebarNameTextBlock"
                                               Text="Modern Sidebar"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ModernSidebarDescriptionTextBlock"
                                               Text="Compact sidebar with a dark name band and focused content."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="ModernSidebarSelectedTextBlock"
                                               Text="Selected"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="CleanTopHeaderTemplateButton"
                                    Width="220"
                                    MinHeight="190"
                                    Margin="0,0,16,16"
                                    Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Click="OnSelectCleanTopHeaderTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Grid Height="86"
                                          RowDefinitions="34,*">
                                        <Border Background="#5A9BD5" />
                                        <Border Grid.Row="1"
                                                Background="White" />
                                    </Grid>
                                    <TextBlock x:Name="CleanTopHeaderNameTextBlock"
                                               Text="Clean Top Header"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="CleanTopHeaderDescriptionTextBlock"
                                               Text="Safe default with a full-width color header and simple sections."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="CleanTopHeaderSelectedTextBlock"
                                               Text="Selected"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="DarkSidebarTemplateButton"
                                    Width="220"
                                    MinHeight="190"
                                    Margin="0,0,16,16"
                                    Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Click="OnSelectDarkSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Grid Height="86"
                                          ColumnDefinitions="72,*">
                                        <Border Background="#2F3A45" />
                                        <Grid Grid.Column="1"
                                              RowDefinitions="28,*">
                                            <Border Background="#5B9BB0" />
                                            <Border Grid.Row="1"
                                                    Background="#F2F2F2" />
                                        </Grid>
                                    </Grid>
                                    <TextBlock x:Name="DarkSidebarAccentNameTextBlock"
                                               Text="Dark Sidebar Accent"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="DarkSidebarAccentDescriptionTextBlock"
                                               Text="Dark sidebar, colored header, and stronger visual personality."
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="DarkSidebarSelectedTextBlock"
                                               Text="Selected"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </ScrollViewer>

                    <Button x:Name="TemplatesBottomCloseButton"
                            Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseTemplatesClicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
