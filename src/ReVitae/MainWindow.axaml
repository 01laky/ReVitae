<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="ReVitae.MainWindow"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="600"
        Width="900"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        Title="ReVitae"
        KeyDown="OnWindowKeyDown"
        SizeChanged="OnWindowSizeChanged">
    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,*"
          Margin="24">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="ReVitae"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Text="Create a simple CV preview and export a plain PDF."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="OpenSetupButton"
                        Width="56"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnOpenSetupClicked"
                        ToolTip.Tip="Open setup"
                        AutomationProperties.Name="Open setup">
                    <TextBlock Text="⚙"
                               FontSize="32"
                               LineHeight="32"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>

                <Button x:Name="OpenTemplatesButton"
                        Width="56"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnOpenTemplatesClicked"
                        ToolTip.Tip="Open templates"
                        AutomationProperties.Name="Open templates">
                    <TextBlock Text="🎨"
                               FontSize="28"
                               LineHeight="28"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,24,0,0"
              ColumnDefinitions="*,*"
              ColumnSpacing="24">
            <ScrollViewer Grid.Column="0">
                <Border Padding="20"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Main / Personal information"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="First name" />
                            <TextBox x:Name="FirstNameTextBox"
                                     PlaceholderText="John"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="FirstNameErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Last name" />
                            <TextBox x:Name="LastNameTextBox"
                                     PlaceholderText="Doe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LastNameErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Professional title" />
                            <TextBox x:Name="ProfessionalTitleTextBox"
                                     PlaceholderText="Frontend Developer"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ProfessionalTitleErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Email" />
                            <TextBox x:Name="EmailTextBox"
                                     PlaceholderText="john.doe@example.com"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="EmailErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Phone" />
                            <TextBox x:Name="PhoneTextBox"
                                     PlaceholderText="+421 900 000 000"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PhoneErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Location" />
                            <TextBox x:Name="LocationTextBox"
                                     PlaceholderText="Bratislava, Slovakia"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LocationErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="LinkedIn URL" />
                            <TextBox x:Name="LinkedInUrlTextBox"
                                     PlaceholderText="https://www.linkedin.com/in/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LinkedInUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Portfolio / website URL" />
                            <TextBox x:Name="PortfolioUrlTextBox"
                                     PlaceholderText="https://johndoe.dev"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PortfolioUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="GitHub URL" />
                            <TextBox x:Name="GitHubUrlTextBox"
                                     PlaceholderText="https://github.com/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="GitHubUrlErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Short summary" />
                            <TextBox x:Name="ShortSummaryTextBox"
                                     AcceptsReturn="True"
                                     MinHeight="96"
                                     TextWrapping="Wrap"
                                     PlaceholderText="Write two to four sentences about your professional profile."
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ShortSummaryErrorTextBlock"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                        </StackPanel>

                        <TextBlock x:Name="ValidationSummaryTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />

                        <Button x:Name="ExportPdfButton"
                                Content="Export PDF"
                                HorizontalAlignment="Left"
                                Click="OnExportPdfClicked" />

                        <TextBlock x:Name="ExportStatusTextBlock"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Padding="20"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock Text="Preview"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <Border Padding="16"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            CornerRadius="6">
                        <TextBlock x:Name="PreviewTextBlock"
                                   FontFamily="Consolas, Menlo, monospace"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SetupModalOverlay"
              Grid.RowSpan="2"
              Background="#99000000"
              IsVisible="False">
            <Border x:Name="SetupModalPanel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock Text="Setup"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Close"
                                Click="OnCloseSetupClicked" />
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,24,0,0"
                               Text="Setup options will be added in a future step."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <Button Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseSetupClicked" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TemplatesModalOverlay"
              Grid.RowSpan="2"
              Background="#99000000"
              IsVisible="False">
            <Border x:Name="TemplatesModalPanel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock Text="Templates"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Close"
                                Click="OnCloseTemplatesClicked" />
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,24,0,0"
                               Text="Template selection will be added in a future step."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <Button Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseTemplatesClicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
