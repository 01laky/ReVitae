<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:ReVitae.Core.Localization;assembly=ReVitae.Core"
        xmlns:controls="clr-namespace:ReVitae.Controls"
        xmlns:workExperience="clr-namespace:ReVitae.WorkExperience"
        xmlns:education="clr-namespace:ReVitae.Education"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="ReVitae.MainWindow"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="600"
        Width="900"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        Title="ReVitae"
        KeyDown="OnWindowKeyDown"
        SizeChanged="OnWindowSizeChanged">
    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,*"
          Margin="24">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
            <StackPanel Grid.Column="0"
                        Classes="re-vitae-page">
                <TextBlock Text="ReVitae"
                           Classes="re-vitae-app-title" />
                <TextBlock x:Name="HeaderSubtitleTextBlock"
                           Classes="re-vitae-subtitle"
                           Text="Create a simple CV preview and export a plain PDF." />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="OpenSetupButton"
                        Classes="re-vitae-icon-button"
                        Click="OnOpenSetupClicked"
                        ToolTip.Tip="Open setup"
                        AutomationProperties.Name="Open setup">
                    <materialIcons:MaterialIcon Kind="Cog"
                                                Width="24"
                                                Height="24" />
                </Button>

                <Button x:Name="OpenTemplatesButton"
                        Classes="re-vitae-icon-button"
                        Click="OnOpenTemplatesClicked"
                        ToolTip.Tip="Open templates"
                        AutomationProperties.Name="Open templates">
                    <materialIcons:MaterialIcon Kind="Palette"
                                                Width="24"
                                                Height="24" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="0,24,0,0"
              ColumnDefinitions="*,*"
              ColumnSpacing="24">
            <ScrollViewer Grid.Column="0">
                <Border Classes="re-vitae-app-card">
                    <StackPanel Classes="re-vitae-section-body">
                        <controls:ExpandableSection x:Name="PersonalInformationSection"
                                                    IsExpanded="True">
                            <controls:ExpandableSection.SectionContent>
                                <StackPanel Classes="re-vitae-section-body">
                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="FirstNameLabelTextBlock" Text="First name" />
                            <TextBox x:Name="FirstNameTextBox"
                                     PlaceholderText="John"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="FirstNameErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="LastNameLabelTextBlock" Text="Last name" />
                            <TextBox x:Name="LastNameTextBox"
                                     PlaceholderText="Doe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LastNameErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="ProfessionalTitleLabelTextBlock" Text="Professional title" />
                            <TextBox x:Name="ProfessionalTitleTextBox"
                                     PlaceholderText="Frontend Developer"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ProfessionalTitleErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="EmailLabelTextBlock" Text="Email" />
                            <TextBox x:Name="EmailTextBox"
                                     PlaceholderText="john.doe@example.com"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="EmailErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="PhoneLabelTextBlock" Text="Phone" />
                            <TextBox x:Name="PhoneTextBox"
                                     PlaceholderText="+421 900 000 000"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PhoneErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="LocationLabelTextBlock" Text="Location" />
                            <TextBox x:Name="LocationTextBox"
                                     PlaceholderText="Bratislava, Slovakia"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LocationErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="LinkedInUrlLabelTextBlock" Text="LinkedIn URL" />
                            <TextBox x:Name="LinkedInUrlTextBox"
                                     PlaceholderText="https://www.linkedin.com/in/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="LinkedInUrlErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="PortfolioUrlLabelTextBlock" Text="Portfolio / website URL" />
                            <TextBox x:Name="PortfolioUrlTextBox"
                                     PlaceholderText="https://johndoe.dev"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="PortfolioUrlErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="GitHubUrlLabelTextBlock" Text="GitHub URL" />
                            <TextBox x:Name="GitHubUrlTextBox"
                                     PlaceholderText="https://github.com/johndoe"
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="GitHubUrlErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="ShortSummaryLabelTextBlock" Text="Short summary" />
                            <TextBox x:Name="ShortSummaryTextBox"
                                     Classes="re-vitae-multiline"
                                     PlaceholderText="Write two to four sentences about your professional profile."
                                     TextChanged="OnFormTextChanged" />
                            <TextBlock x:Name="ShortSummaryErrorTextBlock"
                                       Classes="re-vitae-error" />
                        </StackPanel>
                                </StackPanel>
                            </controls:ExpandableSection.SectionContent>
                        </controls:ExpandableSection>

                        <workExperience:WorkExperienceSectionView x:Name="WorkExperienceSection" />

                        <education:EducationSectionView x:Name="EducationSection" />

                        <TextBlock x:Name="ValidationSummaryTextBlock"
                                   Classes="re-vitae-error" />

                        <Button x:Name="ExportPdfButton"
                                Classes="re-vitae-primary"
                                Content="Export PDF"
                                Click="OnExportPdfClicked" />

                        <TextBlock x:Name="ExportStatusTextBlock"
                                   Classes="re-vitae-secondary" />
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Column="1"
                    Classes="re-vitae-app-card">
                <StackPanel Classes="re-vitae-preview-chrome">
                    <Grid Classes="re-vitae-section-header"
                          ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                Classes="re-vitae-section-header-spacer" />
                        <TextBlock x:Name="PreviewTitleTextBlock"
                                   Grid.Column="1"
                                   Classes="re-vitae-section-title"
                                   VerticalAlignment="Center"
                                   Text="Preview" />
                        <Button x:Name="OpenPreviewExpandButton"
                                Grid.Column="2"
                                Classes="re-vitae-expand-toggle"
                                Click="OnOpenPreviewExpandClicked"
                                ToolTip.Tip="Expand preview"
                                AutomationProperties.Name="Expand preview">
                            <materialIcons:MaterialIcon Kind="ArrowExpand"
                                                        Width="22"
                                                        Height="22" />
                        </Button>
                    </Grid>
                    <Border Classes="re-vitae-preview-surface">
                        <ScrollViewer Classes="re-vitae-preview-scroll">
                            <ContentControl x:Name="PreviewContentControl" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SetupModalOverlay"
              Grid.RowSpan="2"
              Classes="re-vitae-modal-overlay"
              IsVisible="False">
            <Border x:Name="SetupModalPanel"
                    Classes="re-vitae-modal-panel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock x:Name="SetupTitleTextBlock"
                                   Classes="re-vitae-app-title"
                                   FontSize="24"
                                   Text="Setup"
                                   VerticalAlignment="Center" />
                        <Button x:Name="SetupTopCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="OnCloseSetupClicked" />
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="0,14,0,0"
                                Classes="re-vitae-section-body">
                        <TextBlock x:Name="SetupPlaceholderTextBlock"
                                   Classes="re-vitae-secondary"
                                   Text="Setup options will be added in a future step." />

                        <StackPanel Classes="re-vitae-form-field">
                            <TextBlock x:Name="LanguageLabelTextBlock"
                                       Text="Language" />
                            <ComboBox x:Name="LanguageComboBox"
                                      MinWidth="220"
                                      SelectionChanged="OnLanguageSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="loc:SupportedLanguage">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding FlagEmoji}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding NativeName}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="SetupBottomCloseButton"
                            Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseSetupClicked" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TemplatesModalOverlay"
              Grid.RowSpan="2"
              Classes="re-vitae-modal-overlay"
              IsVisible="False">
            <Border x:Name="TemplatesModalPanel"
                    Classes="re-vitae-modal-panel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock x:Name="TemplatesTitleTextBlock"
                                   Classes="re-vitae-app-title"
                                   FontSize="24"
                                   Text="Templates"
                                   VerticalAlignment="Center" />
                        <Button x:Name="TemplatesTopCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="OnCloseTemplatesClicked" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,14,0,0">
                        <WrapPanel>
                            <Button x:Name="ClassicSidebarTemplateButton"
                                    Classes="re-vitae-template-card"
                                    Click="OnSelectClassicSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Border Classes="re-vitae-template-thumbnail">
                                        <Grid ColumnDefinitions="36*,64*">
                                            <Border Grid.Column="0"
                                                    Background="#D8D8D8" />
                                            <Border Grid.Column="1"
                                                    Background="White" />
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="ClassicSidebarNameTextBlock"
                                               Text="Classic Sidebar"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ClassicSidebarDescriptionTextBlock"
                                               Classes="re-vitae-secondary"
                                               Text="Light sidebar with contact details and a clean content area." />
                                    <TextBlock x:Name="ClassicSidebarSelectedTextBlock"
                                               Classes="re-vitae-accent"
                                               Text="Selected" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="ModernSidebarTemplateButton"
                                    Classes="re-vitae-template-card"
                                    Click="OnSelectModernSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Border Classes="re-vitae-template-thumbnail">
                                        <Grid ColumnDefinitions="34*,66*"
                                              RowDefinitions="32*,68*">
                                            <Border Grid.RowSpan="2"
                                                    Background="#D7D7D7" />
                                            <Border Grid.Column="1"
                                                    Grid.Row="0"
                                                    Background="#444444" />
                                            <Border Grid.Column="1"
                                                    Grid.Row="1"
                                                    Background="White" />
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="ModernSidebarNameTextBlock"
                                               Text="Modern Sidebar"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ModernSidebarDescriptionTextBlock"
                                               Classes="re-vitae-secondary"
                                               Text="Compact sidebar with a dark name band and focused content." />
                                    <TextBlock x:Name="ModernSidebarSelectedTextBlock"
                                               Classes="re-vitae-accent"
                                               Text="Selected" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="CleanTopHeaderTemplateButton"
                                    Classes="re-vitae-template-card"
                                    Click="OnSelectCleanTopHeaderTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Border Classes="re-vitae-template-thumbnail">
                                        <Grid RowDefinitions="39*,61*">
                                            <Border Background="#5A9BD5" />
                                            <Border Grid.Row="1"
                                                    Background="White" />
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="CleanTopHeaderNameTextBlock"
                                               Text="Clean Top Header"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="CleanTopHeaderDescriptionTextBlock"
                                               Classes="re-vitae-secondary"
                                               Text="Safe default with a full-width color header and simple sections." />
                                    <TextBlock x:Name="CleanTopHeaderSelectedTextBlock"
                                               Classes="re-vitae-accent"
                                               Text="Selected" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="DarkSidebarTemplateButton"
                                    Classes="re-vitae-template-card"
                                    Click="OnSelectDarkSidebarTemplateClicked">
                                <StackPanel Spacing="10">
                                    <Border Classes="re-vitae-template-thumbnail">
                                        <Grid ColumnDefinitions="34*,66*">
                                            <Border Background="#2F3A45" />
                                            <Grid Grid.Column="1"
                                                  RowDefinitions="32*,68*">
                                                <Border Background="#5B9BB0" />
                                                <Border Grid.Row="1"
                                                        Background="#F2F2F2" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="DarkSidebarAccentNameTextBlock"
                                               Text="Dark Sidebar Accent"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="DarkSidebarAccentDescriptionTextBlock"
                                               Classes="re-vitae-secondary"
                                               Text="Dark sidebar, colored header, and stronger visual personality." />
                                    <TextBlock x:Name="DarkSidebarSelectedTextBlock"
                                               Classes="re-vitae-accent"
                                               Text="Selected" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </ScrollViewer>

                    <Button x:Name="TemplatesBottomCloseButton"
                            Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseTemplatesClicked" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="PreviewExpandModalOverlay"
              Grid.RowSpan="2"
              Classes="re-vitae-modal-overlay"
              IsVisible="False">
            <Border x:Name="PreviewExpandModalPanel"
                    Classes="re-vitae-modal-panel"
                    MaxWidth="1100"
                    MaxHeight="800"
                    MinWidth="360"
                    MinHeight="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <TextBlock x:Name="PreviewExpandTitleTextBlock"
                                   Classes="re-vitae-app-title"
                                   FontSize="24"
                                   Text="Expanded preview"
                                   VerticalAlignment="Center" />
                        <Button x:Name="PreviewExpandTopCloseButton"
                                Grid.Column="1"
                                Content="Close"
                                Click="OnClosePreviewExpandClicked" />
                    </Grid>

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Stretch"
                                Classes="re-vitae-preview-chrome">
                        <Border Classes="re-vitae-preview-surface">
                            <ScrollViewer Classes="re-vitae-preview-scroll">
                                <ContentControl x:Name="PreviewExpandContentControl" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <Button x:Name="PreviewExpandBottomCloseButton"
                            Grid.Row="2"
                            Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnClosePreviewExpandClicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
