root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_style = tab
indent_size = tab

[*.{axaml,xaml}]
indent_style = tab
indent_size = tab

[*.{csproj,props,targets,xml,axml,manifest}]
indent_style = tab
indent_size = tab

[*.sh]
indent_style = tab
indent_size = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2

[package-lock.json]
indent_style = space
indent_size = 2

dotnet_sort_system_directives_first = true
dotnet_separate_import_directives_groups = false

csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
