root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_style = tab
indent_size = tab

# 047 QG5 — code-quality guardrails (IDE guidance; the build is kept clean via
# TreatWarningsAsErrors). These flag the smells this refactor removed so they do not
# silently return: unused usings/members, missing readonly, and avoidable allocations.
dotnet_diagnostic.IDE0005.severity = suggestion   # unnecessary using directive
dotnet_diagnostic.IDE0051.severity = suggestion   # unused private member
dotnet_diagnostic.IDE0052.severity = suggestion   # unread private member
dotnet_diagnostic.CA1822.severity = suggestion    # member can be static
dotnet_style_readonly_field = true:suggestion
csharp_prefer_braces = true:suggestion

[*.{axaml,xaml}]
indent_style = tab
indent_size = tab

[*.{csproj,props,targets,xml,axml,manifest}]
indent_style = tab
indent_size = tab

[*.sh]
indent_style = tab
indent_size = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2

[package-lock.json]
indent_style = space
indent_size = 2

dotnet_sort_system_directives_first = true
dotnet_separate_import_directives_groups = false

csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
